# ─── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=sk-...
OPENAI_LLM_MODEL=gpt-4o
OPENAI_LLM_FALLBACK_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# ─── PostgreSQL ────────────────────────────────────────────
POSTGRES_USER=atendai
POSTGRES_PASSWORD=atendai
POSTGRES_DB=atendai
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://atendai:atendai@localhost:5432/atendai

# ─── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── ChromaDB ──────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001

# ─── Evolution API (WhatsApp) ──────────────────────────────
EVOLUTION_API_URL=http://localhost:8080
EVOLUTION_API_KEY=changeme
EVOLUTION_INSTANCE_NAME=atendai

# ─── Interface Admin ───────────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=changeme

# ─── Aplicação ─────────────────────────────────────────────
APP_ENV=development
APP_SECRET_KEY=changeme-use-secrets-generate-in-production
LOG_LEVEL=INFO
